# --- Python / env ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# --- Streamlit secrets ---
.streamlit/secrets.toml

# --- Raw IMD downloads (regenerated by data/prepare.py; ~1 GB, not needed at runtime) ---
data/raw/

# --- Rebuildable large cache (regenerated on first run from obs.nc in ~4s) ---
data/processed/anom_cube.npy

# --- OS cruft ---
.DS_Store
Thumbs.db
*.swp

# NOTE: the deployable cache IS committed (via Git LFS) so the app runs on
# Hugging Face out of the box:
#   data/processed/{obs.nc, clim_rain.nc, clim_temp.nc, stats.json, landmask.npy,
#                   grid.npz, meta.json}
#   models/checkpoints/{climate_unet.pt, xgb_*.json}
#   data/geojson/india_states.geojson · data/insat/*.h5 · outputs/*.png
